# AI Spider Configuration
# Copy to .env and fill in your values

# LLM Provider (deepseek recommended for Chinese sites)
LLM_PROVIDER=deepseek
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-chat
# LLM_BASE_URL=https://api.deepseek.com/v1  # optional, auto-detected by provider

# Redis (distributed queue + dedup)
REDIS_URL=redis://127.0.0.1:6379/2

# PostgreSQL (metadata storage)
DATABASE_URL=postgresql://openclaw_app:password@127.0.0.1:5432/openclaw_core

# Server
HOST=0.0.0.0
PORT=8900
DEBUG=true

# Sandbox
SANDBOX_TIMEOUT=30
SANDBOX_MAX_PAGES=10

# Crawler defaults
DEFAULT_CONCURRENCY=3
DEFAULT_DELAY=1.0
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
