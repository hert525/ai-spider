[Unit]
Description=AI Spider Worker
After=network.target ai-spider.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/.openclaw/workspace/ai-spider
ExecStart=/www/python311/bin/python3.11 worker.py --master http://127.0.0.1:8901 --concurrency 3
Restart=always
RestartSec=5
EnvironmentFile=/root/.openclaw/workspace/ai-spider/.env
Environment=PYTHONPATH=/root/.openclaw/workspace/ai-spider

[Install]
WantedBy=multi-user.target
